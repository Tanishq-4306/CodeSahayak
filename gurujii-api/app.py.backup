    pipeline,
    AutoTokenizer,
    AutoModelForSeq2SeqLM,
    VitsModel
)
import soundfile as sf
import os
from datetime import datetime

app = Flask(__name__)
CORS(app)  # Enable CORS for frontend requests

# Global model variables
generator = None
translator_tokenizer = None
translator_model = None
tts_model = None
tts_tokenizer = None

